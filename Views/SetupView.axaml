<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TodoApp.Views.SetupView"
             Background="White">
    <Border Padding="40" VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="24" Width="500">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <TextBlock Text="&#xf013;" FontFamily="{StaticResource FontAwesome}"
                           FontSize="24" Foreground="#333333" VerticalAlignment="Center"/>
                <TextBlock Text="Configuración Inicial"
                           FontSize="26" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#333333"/>
            </StackPanel>

            <Border Height="2" Background="#17A2B8"/>

            <TextBlock Text="No se ha configurado una base de datos SQLite. Por favor seleccione la ubicación donde se creará el archivo de base de datos."
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Foreground="#555555" FontSize="14"
                       TextAlignment="Center"/>

            <StackPanel Spacing="6">
                <TextBlock Text="Ubicación de la base de datos" FontWeight="SemiBold"
                           FontSize="14" Foreground="#333333"/>
                <TextBox x:Name="PathTextBox"
                         PlaceholderText="Ruta del archivo SQLite (.db)"
                         IsReadOnly="True"
                         BorderBrush="#CCCCCC" BorderThickness="1"
                         CornerRadius="3" Padding="10,8" FontSize="14"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                <Button Click="OnSelectPath"
                        Classes="btn-info"
                        ToolTip.Tip="Elegir dónde guardar la base de datos"
                        FontWeight="SemiBold" Padding="20,10" FontSize="14">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xf07c;" FontFamily="{StaticResource FontAwesome}"
                                   FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="Seleccionar ubicación..." Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border Height="1" Background="#EEEEEE"/>

            <Button Click="OnCreate"
                    HorizontalAlignment="Center"
                    IsEnabled="False"
                    x:Name="CreateButton"
                    Classes="btn-success"
                    ToolTip.Tip="Crear la base de datos e iniciar la aplicación"
                    FontWeight="SemiBold" Padding="24,10" FontSize="14">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#xf1c0;" FontFamily="{StaticResource FontAwesome}"
                               FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Crear base de datos e iniciar" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
