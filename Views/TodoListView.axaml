<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TodoApp.ViewModels"
             x:Class="TodoApp.Views.TodoListView"
             x:DataType="vm:MainViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="24,20">

        <!-- Alert Banner -->
        <Border Grid.Row="0"
                Background="{DynamicResource AlertBackground}" BorderBrush="{DynamicResource AlertBorder}" BorderThickness="1"
                CornerRadius="4" Padding="16,12" Margin="0,0,0,16"
                IsVisible="{Binding IsAlertVisible}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="&#xf058;" FontFamily="{StaticResource FontAwesome}"
                           FontSize="16" Foreground="{DynamicResource AlertForeground}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding AlertMessage}"
                           Foreground="{DynamicResource AlertForeground}" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Header -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="0">
                <TextBlock Text="&#xf013;" FontFamily="{StaticResource FontAwesome}"
                           FontSize="22" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Text="Tareas" FontSize="24" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
            </StackPanel>
            <Button Grid.Column="2" Click="OnExport"
                    Classes="btn-success"
                    ToolTip.Tip="Exportar todas las tareas a Excel"
                    FontWeight="SemiBold" Padding="20,8" FontSize="14"
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#xf1c3;" FontFamily="{StaticResource FontAwesome}"
                               FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Exportar" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Click="OnNew"
                    Classes="btn-outline-warning"
                    ToolTip.Tip="Crear nueva tarea"
                    FontWeight="SemiBold" Padding="20,8" FontSize="14">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#xf067;" FontFamily="{StaticResource FontAwesome}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="Nuevo" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Toolbar: Page size + Search -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*,Auto" Margin="0,0,0,16">
            <TextBlock Text="Mostrar" VerticalAlignment="Center" Grid.Column="0"
                       Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
            <ComboBox ItemsSource="{Binding PageSizeOptions}"
                      SelectedItem="{Binding PageSize}"
                      Margin="8,0" Width="75"
                      VerticalAlignment="Center" Grid.Column="1"
                      FontSize="13"/>
            <TextBlock Text="registros por página" VerticalAlignment="Center" Grid.Column="2"
                       Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
            <TextBox PlaceholderText="Buscar..."
                     Text="{Binding SearchText}"
                     Width="220"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Right"
                     Grid.Column="4"
                     FontSize="13"
                     BorderBrush="{DynamicResource BorderInput}"
                     BorderThickness="1"
                     CornerRadius="3"
                     Padding="8,6"/>
        </Grid>

        <!-- Data Grid -->
        <DataGrid Grid.Row="3"
                  x:Name="TodoGrid"
                  ItemsSource="{Binding Todos}"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="False"
                  GridLinesVisibility="All"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  FontSize="14"
                  Sorting="OnGridSorting">
            <DataGrid.Columns>
                <DataGridTemplateColumn SortMemberPath="Title" Width="2*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock x:CompileBindings="False"
                                       Text="{Binding DataContext.TitleHeader, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontWeight="Bold" FontSize="14"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:TodoItemViewModel">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="12,0"
                                       ToolTip.Tip="{Binding Id, StringFormat='Registro: {0}'}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Binding="{Binding Text}"
                                    SortMemberPath="Text"
                                    Width="2*">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock x:CompileBindings="False"
                                       Text="{Binding DataContext.TextHeader, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontWeight="Bold" FontSize="14"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                <DataGridTemplateColumn SortMemberPath="Status" Width="*">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock x:CompileBindings="False"
                                       Text="{Binding DataContext.StatusHeader, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontWeight="Bold" FontSize="14"
                                       VerticalAlignment="Center"
                                       ToolTip.Tip="Estado de la tarea:&#10;• Creado — tarea pendiente de iniciar&#10;• En Ejecución — tarea en progreso&#10;• Terminado — tarea completada"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:TodoItemViewModel">
                            <Border CornerRadius="12" Padding="12,4"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="4,2"
                                    Background="{Binding Status, Converter={x:Static vm:TodoItemViewModel.StatusBackgroundConverter}}"
                                    BorderBrush="{Binding Status, Converter={x:Static vm:TodoItemViewModel.StatusBorderConverter}}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding StatusDisplay}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding Status, Converter={x:Static vm:TodoItemViewModel.StatusForegroundConverter}}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="110" CanUserSort="False" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:TodoItemViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="4,0">
                                <Button Click="OnEdit" Tag="{Binding}"
                                        Classes="btn-warning"
                                        ToolTip.Tip="Editar tarea"
                                        Padding="10,6">
                                    <TextBlock Text="&#xf044;" FontFamily="{StaticResource FontAwesome}"
                                               FontSize="14" Foreground="White"/>
                                </Button>
                                <Button Click="OnDelete" Tag="{Binding}"
                                        Classes="btn-danger"
                                        ToolTip.Tip="Eliminar tarea"
                                        Padding="10,6">
                                    <TextBlock Text="&#xf2ed;" FontFamily="{StaticResource FontAwesome}"
                                               FontSize="14" Foreground="White"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer: Pagination -->
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
            <TextBlock Text="{Binding PageInfo}" VerticalAlignment="Center" Grid.Column="0"
                       Foreground="{DynamicResource TextFooter}" FontSize="13"/>
            <StackPanel Orientation="Horizontal" Spacing="8" Grid.Column="1">
                <Button Command="{Binding PreviousPageCommand}"
                        Classes="btn-page"
                        ToolTip.Tip="Página anterior"
                        Padding="12,6" FontSize="13">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#xf053;" FontFamily="{StaticResource FontAwesome}"
                                   FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Text="Anterior" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" FontSize="13">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Página {0} de {1}">
                            <Binding Path="CurrentPage"/>
                            <Binding Path="TotalPages"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <Button Command="{Binding NextPageCommand}"
                        Classes="btn-page"
                        ToolTip.Tip="Página siguiente"
                        Padding="12,6" FontSize="13">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Siguiente" VerticalAlignment="Center"/>
                        <TextBlock Text="&#xf054;" FontFamily="{StaticResource FontAwesome}"
                                   FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
