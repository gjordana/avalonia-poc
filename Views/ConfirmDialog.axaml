<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TodoApp.Views.ConfirmDialog"
        Title="Confirmar"
        Width="450" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppBackground}">

    <Grid RowDefinitions="*,Auto" Margin="28,24">
        <StackPanel Grid.Row="0" Spacing="12" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="&#xf071;" FontFamily="{StaticResource FontAwesome}"
                           FontSize="22" Foreground="#E8A317" VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="MessageText" FontSize="14" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondary}" Margin="32,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Click="OnCancel"
                    Classes="btn-page"
                    FontWeight="SemiBold" Padding="20,10" FontSize="14">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#xf00d;" FontFamily="{StaticResource FontAwesome}"
                               FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Click="OnConfirm"
                    Classes="btn-danger"
                    FontWeight="SemiBold" Padding="20,10" FontSize="14">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#xf2ed;" FontFamily="{StaticResource FontAwesome}"
                               FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Eliminar" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
