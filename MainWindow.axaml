<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TodoApp.MainWindow"
        Title="TodoApp - Gestión de Tareas"
        Width="800" Height="600"
        MinWidth="600" MinHeight="400">
    <Grid RowDefinitions="Auto,*">
        <!-- Theme Toggle Bar -->
        <Border Grid.Row="0" Padding="12,6" Background="{DynamicResource ThemeToggleBarBackground}">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                <TextBlock Text="&#xf185;" FontFamily="{StaticResource FontAwesome}"
                           FontSize="14" VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeToggleText}"/>
                <ToggleSwitch x:Name="ThemeToggle"
                              OnContent="Dark" OffContent="Light"
                              IsChecked="False"
                              IsCheckedChanged="OnThemeToggleChanged"
                              VerticalAlignment="Center"
                              Margin="0,-2,0,0"/>
                <TextBlock Text="&#xf186;" FontFamily="{StaticResource FontAwesome}"
                           FontSize="14" VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeToggleText}"/>
            </StackPanel>
        </Border>

        <ContentControl x:Name="MainContent" Grid.Row="1"/>
    </Grid>
</Window>
