<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TodoApp.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="FontAwesome">avares://TodoApp/Assets/Fonts/fa-solid-900.ttf#Font Awesome 6 Free Solid</FontFamily>

            <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="AppBackground" Color="White"/>
                <SolidColorBrush x:Key="TextPrimary" Color="#333333"/>
                <SolidColorBrush x:Key="TextSecondary" Color="#555555"/>
                <SolidColorBrush x:Key="TextMuted" Color="#777777"/>
                <SolidColorBrush x:Key="TextFooter" Color="#888888"/>
                <SolidColorBrush x:Key="BorderLight" Color="#EEEEEE"/>
                <SolidColorBrush x:Key="BorderMedium" Color="#DDDDDD"/>
                <SolidColorBrush x:Key="BorderInput" Color="#CCCCCC"/>
                <SolidColorBrush x:Key="InputBackground" Color="White"/>
                <SolidColorBrush x:Key="PageBtnBackground" Color="White"/>
                <SolidColorBrush x:Key="PageBtnHover" Color="#F0F0F0"/>
                <SolidColorBrush x:Key="PageBtnPressed" Color="#E0E0E0"/>
                <SolidColorBrush x:Key="HeaderHover" Color="#F5F5F5"/>
                <SolidColorBrush x:Key="HeaderPressed" Color="#EBEBEB"/>
                <SolidColorBrush x:Key="AlertBackground" Color="#D4EDDA"/>
                <SolidColorBrush x:Key="AlertBorder" Color="#C3E6CB"/>
                <SolidColorBrush x:Key="AlertForeground" Color="#155724"/>
                <SolidColorBrush x:Key="ThemeToggleBarBackground" Color="#F8F9FA"/>
                <SolidColorBrush x:Key="ThemeToggleText" Color="#555555"/>
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="AppBackground" Color="#1E1E2E"/>
                <SolidColorBrush x:Key="TextPrimary" Color="#CDD6F4"/>
                <SolidColorBrush x:Key="TextSecondary" Color="#BAC2DE"/>
                <SolidColorBrush x:Key="TextMuted" Color="#A6ADC8"/>
                <SolidColorBrush x:Key="TextFooter" Color="#7F849C"/>
                <SolidColorBrush x:Key="BorderLight" Color="#313244"/>
                <SolidColorBrush x:Key="BorderMedium" Color="#45475A"/>
                <SolidColorBrush x:Key="BorderInput" Color="#585B70"/>
                <SolidColorBrush x:Key="InputBackground" Color="#313244"/>
                <SolidColorBrush x:Key="PageBtnBackground" Color="#313244"/>
                <SolidColorBrush x:Key="PageBtnHover" Color="#45475A"/>
                <SolidColorBrush x:Key="PageBtnPressed" Color="#585B70"/>
                <SolidColorBrush x:Key="HeaderHover" Color="#313244"/>
                <SolidColorBrush x:Key="HeaderPressed" Color="#45475A"/>
                <SolidColorBrush x:Key="AlertBackground" Color="#1E3A2F"/>
                <SolidColorBrush x:Key="AlertBorder" Color="#2D5A45"/>
                <SolidColorBrush x:Key="AlertForeground" Color="#A6E3A1"/>
                <SolidColorBrush x:Key="ThemeToggleBarBackground" Color="#181825"/>
                <SolidColorBrush x:Key="ThemeToggleText" Color="#BAC2DE"/>
            </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- TextBox: theme-aware background -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        </Style>

        <!-- btn-warning (yellow/edit) -->
        <Style Selector="Button.btn-warning">
            <Setter Property="Background" Value="#E8A317"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-warning:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#D4940F"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-warning:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#C0860D"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- btn-danger (red/delete) -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Background" Value="#DC3545"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#C82333"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-danger:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#B21F2D"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- btn-info (teal/volver) -->
        <Style Selector="Button.btn-info">
            <Setter Property="Background" Value="#17A2B8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-info:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#138496"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-info:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#10707F"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- btn-success (green/guardar) -->
        <Style Selector="Button.btn-success">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-success:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#218838"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-success:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1E7E34"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- btn-outline-warning (Nuevo button) -->
        <Style Selector="Button.btn-outline-warning">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8A317"/>
            <Setter Property="BorderBrush" Value="#E8A317"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-outline-warning:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E8A317"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8A317"/>
        </Style>
        <Style Selector="Button.btn-outline-warning:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#D4940F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#D4940F"/>
        </Style>

        <!-- btn-page (pagination) -->
        <Style Selector="Button.btn-page">
            <Setter Property="Background" Value="{DynamicResource PageBtnBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMedium}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.btn-page:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PageBtnHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderInput}"/>
        </Style>
        <Style Selector="Button.btn-page:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PageBtnPressed}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
        <!-- btn-header (sortable column headers) -->
        <Style Selector="Button.btn-header">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="Button.btn-header:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HeaderHover}"/>
        </Style>
        <Style Selector="Button.btn-header:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HeaderPressed}"/>
        </Style>
    </Application.Styles>
</Application>
